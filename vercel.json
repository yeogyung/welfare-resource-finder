{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/public/icons/favicon-32.png"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ]
}
